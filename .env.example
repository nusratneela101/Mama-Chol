# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mamachol
REDIS_URL=redis://localhost:6379

# JWT
SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Payment Gateways
BKASH_APP_KEY=your-bkash-app-key
BKASH_APP_SECRET=your-bkash-app-secret
BKASH_USERNAME=your-bkash-username
BKASH_PASSWORD=your-bkash-password
NAGAD_MERCHANT_ID=your-nagad-merchant-id
NAGAD_MERCHANT_PRIVATE_KEY=your-nagad-private-key
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id

# Currency API
EXCHANGE_RATE_API_KEY=your-api-key

# VPN / X-UI
XUI_URL=http://localhost:54321
XUI_USERNAME=admin
XUI_PASSWORD=admin

# Ollama AI
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# App Settings
APP_NAME=MAMA CHOL VPN
APP_URL=https://mamachol.online
DEBUG=False
